{% set title = "Университетский стоматологический центр" %}
{% extends "layouts/main.njk" %}

{% block content %}

<main class="main">
    <div class="main__container container">
        <div class="main__left">
            <div class="main__head">
                <h1 class="main__title title">Университетский стоматологический центр</h1>
                <div class="main__description">25+ лет опыта и совершенствования в стоматологии. Центр сочетает передовые технологии, авторские методики и междисциплинарный подход.</div>
                <button class="main__btn-mobile btn btn--primary">Записаться на приём</button>
            </div>

            <div class="main__contacts">
                <div class="main__time-work">Ежедневно 9:00-22:00</div>
                <a href="tel:+7 (999) 999-99-99" class="main__phone">+7 (999) 999-99-99</a>
                <div class="main__address">Москва, ул. Улица, 11</div>
                <button class="main__btn btn btn--primary">Записаться на приём</button>
            </div>
        </div>
        <div class="main__right">
            <img class="main__hero" src="/src/assets/img/hero.webp" loading="lazy" alt="Улыбка">
            <div class="main__services">
                <div class="main__services-item">
                    <div class="main__services-icon-box">
                        <img class="main__services-icon" src="/src/assets/img/svg/icon1.svg" loading="lazy" alt="Icon">
                    </div>
                    <div class="main__services-title">Лечение кариеса</div>
                    <a class="main__services-btn btn btn--gray" href="">Подробнее</a>
                </div>
                <div class="main__services-item">
                    <div class="main__services-icon-box">
                        <img class="main__services-icon" src="/src/assets/img/svg/icon2.svg" loading="lazy" alt="Icon">
                    </div>
                    <div class="main__services-title">Имплантация зубов</div>
                    <a class="main__services-btn btn btn--gray" href="">Подробнее</a>
                </div>
                <div class="main__services-item">
                    <div class="main__services-icon-box">
                        <img class="main__services-icon" src="/src/assets/img/svg/icon3.svg" loading="lazy" alt="Icon">
                    </div>
                    <div class="main__services-title">Детская стоматология</div>
                    <a class="main__services-btn btn btn--gray" href="">Подробнее</a>
                </div>
            </div>
        </div>
        <div class="main__contacts-mobile">
            <div class="main__time-work">Ежедневно 9:00-22:00</div>
            <a href="tel:+7 (999) 999-99-99" class="main__phone">+7 (999) 999-99-99</a>
            <div class="main__address">Москва, ул. Улица, 11</div>
        </div>
    </div>
</main>

<section class="main-about mb-indent">
    <div class="main-about__container container">
        <h2 class="title">О центре</h2>
    </div>
</section>

{% endblock %}